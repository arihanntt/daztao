# ─────────────────────────────────────────────────────────────────────────────
# NEXTAUTH CONFIGURATION
# Add these to your .env.local file
# ─────────────────────────────────────────────────────────────────────────────

# Generate a strong secret: run `openssl rand -base64 32` in your terminal
NEXTAUTH_SECRET=your_nextauth_secret_here_replace_this

# Your live domain (or http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH (get from console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI to add in Google Console:
#   http://localhost:3000/api/auth/callback/google
#   https://daztao.online/api/auth/callback/google
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
